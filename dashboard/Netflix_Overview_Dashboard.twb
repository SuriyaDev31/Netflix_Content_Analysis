      <column caption='Duration Minutes' datatype='integer' name='[Calculation_171418263162802177]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [type] = &apos;Movie&apos; THEN&#13;&#10;    INT(REGEXP_REPLACE([duration], &apos;[^0-9]&apos;, &apos;&apos;))&#13;&#10;END' />
