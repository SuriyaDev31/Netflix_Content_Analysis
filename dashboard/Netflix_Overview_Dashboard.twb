    <worksheet name='TV Seasons Distribution'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000'>Distribution of TV Show Seasons on Netflix</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_data' name='federated.05povaf08etz501a1ydig1cd7vbr' />
          </datasources>
          <datasource-dependencies datasource='federated.05povaf08etz501a1ydig1cd7vbr'>
            <column caption='Seasons' datatype='integer' name='[Calculation_171418263162961922]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [type] = &apos;TV Show&apos; THEN&#13;&#10;    INT(REGEXP_REPLACE([duration], &apos;[^0-9]&apos;, &apos;&apos;))&#13;&#10;END' />
            </column>
            <column caption='Duration' datatype='string' name='[duration]' role='dimension' type='nominal' />
            <column-instance column='[show_id]' derivation='None' name='[none:show_id:nk]' pivot='key' type='nominal' />
            <column-instance column='[type]' derivation='None' name='[none:type:nk]' pivot='key' type='nominal' />
            <column-instance column='[year_added]' derivation='None' name='[none:year_added:qk]' pivot='key' type='quantitative' />
            <column caption='Show Id' datatype='string' name='[show_id]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_171418263162961922]' derivation='Sum' name='[sum:Calculation_171418263162961922:qk]' pivot='key' type='quantitative' />
            <column caption='Type' datatype='string' name='[type]' role='dimension' type='nominal' />
            <column caption='Year Added' datatype='real' name='[year_added]' role='dimension' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.05povaf08etz501a1ydig1cd7vbr].[none:type:nk]'>
            <groupfilter function='member' level='[none:type:nk]' member='&quot;TV Show&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
          </filter>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.05povaf08etz501a1ydig1cd7vbr].[none:show_id:nk]' direction='DESC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.05povaf08etz501a1ydig1cd7vbr].[sum:Calculation_171418263162961922:qk]' shelf='rows' />
          </shelf-sorts>
          <slices>
            <column>[federated.05povaf08etz501a1ydig1cd7vbr].[none:type:nk]</column>
            <column>[federated.05povaf08etz501a1ydig1cd7vbr].[none:year_added:qk]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
          </pane>
